    "Cookey can send future login requests from %@ directly to this device. Your push token is only sent to the Cookey relay server you choose and is never shared with third parties." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cookey can send future login requests from %@ directly to this device. Your push token is only sent to the Cookey relay server you choose and is never shared with third parties."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cookey 可以在未来接收来自 %@ 的登录请求并将它们直接发送到此设备。您的推送令牌仅发送至您选择的 Cookey 中继服务器，绝不会与任何第三方分享。"
          }
        }
      }
    },
    "Cookey can use push notifications to refresh future login requests on this device for %@. If you continue, iOS will show the system notification permission prompt and Cookey will wait for the APNs token callback before opening the website." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cookey can use push notifications to refresh future login requests on this device for %@. If you continue, iOS will show the system notification permission prompt and Cookey will wait for the APNs token callback before opening the website."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cookey 可以利用推送通知在此设备上为 %@ 刷新未来的登录请求。如果您继续，iOS 将显示系统通知权限提示，Cookey 将等待 APNs 令牌回调后再打开网站。"
          }
        }
      }
    },
    "Cookey could not start the camera scanner." : {
