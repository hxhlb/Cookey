          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "告诉你的 AI 登录某个网站，它会在终端或对话中生成一个安全的二维码。如果无法扫描，让它提供链接。"
          }
        }
      }
    },
    "Scan the QR code with this app and complete login. Your session will be securely delivered back to your AI.": {
