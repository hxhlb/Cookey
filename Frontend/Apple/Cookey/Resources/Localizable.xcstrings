          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这是首次连接该电脑。请核对下方指纹与终端显示的是否一致。如果不一致，请拒绝连接，因为通信可能已被第三方截获。"
          }
        }
